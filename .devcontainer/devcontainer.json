{
  "name": "hai5016-project (Python 3.11 + uv)",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  "remoteUser": "vscode",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        // Use the repo-local venv created by uv
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  },

  // Install uv, then create/sync the .venv from pyproject.toml
  // - uv venv .venv ensures the venv is exactly where the course expects it
  // - uv sync installs deps (and respects uv.lock if you add one later)
  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && export PATH=\"$HOME/.local/bin:$PATH\" && uv --version && uv venv .venv && uv sync",

  // Useful if you later add a Streamlit app (or other local web server)
  // "forwardPorts": [8501]
}
