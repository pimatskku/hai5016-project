# Example .env for hai5016-project
# Copy this file to .env and fill in real values. Do NOT commit real secrets.

# Azure OpenAI / Foundry credentials
AZURE_FOUNDRY_ENDPOINT=https://your-azure-openai-endpoint/
AZURE_FOUNDRY_MODEL=your_deployment_name
AZURE_FOUNDRY_API_KEY=your_azure_api_key

# Supabase (Postgres + pgvector)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# Weather API (optional / used for meal suggestions)
OPENWEATHER_API_KEY=your_openweather_api_key

# Add other environment variables your setup requires below
# Example:
# DATABASE_URL=postgres://user:pass@host:5432/dbname